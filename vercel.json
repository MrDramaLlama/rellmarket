{
  "functions": {
    "api/*.js": {
      "memory": 128
    }
  },
  "routes": [
    { "src": "^/api/listings/(.+)$",      "dest": "/api/listings?action=$1" },
    { "src": "^/api/trades/(.+)$",        "dest": "/api/trades?action=$1" },
    { "src": "^/api/auctions/(.+)$",      "dest": "/api/auctions?action=$1" },
    { "src": "^/api/auth/(.+)$",          "dest": "/api/auth?action=$1" },
    { "src": "^/api/profile/(.+)$",       "dest": "/api/profile?action=$1" },
    { "src": "^/api/notifications/(.+)$", "dest": "/api/notifications?action=$1" },
    { "src": "^/api/admin/(.+)$",         "dest": "/api/admin?action=$1" },
    { "src": "^/api/values/(.+)$",        "dest": "/api/values?action=$1" },
    { "src": "^/api/ratings/(.+)$",       "dest": "/api/ratings?action=$1" },
    { "src": "^/api/prices/(.+)$",        "dest": "/api/prices?action=$1" },
    { "src": "^/api/traders/(.+)$",       "dest": "/api/traders?action=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
